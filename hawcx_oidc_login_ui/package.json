{
  "name": "hawcx-oidc-login-ui",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Hosted login UI for Hawcx's OIDC /authorize hand-off. Drives @hawcx/react's full SignUpSignIn flow (including ZKP device enrollment), then bounces back to /authorize/resume.",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug"
  },
  "dependencies": {
    "@hawcx/core": "file:../hawcx_web_demo/frontend/sdk/core",
    "@hawcx/react": "file:../hawcx_web_demo/frontend/sdk/react",
    "react": "^18.3.0",
    "react-dom": "^18.3.0"
  },
  "devDependencies": {
    "@types/node": "^25.8.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "typescript": "^5.5.0",
    "vite": "^5.4.0",
    "@playwright/test": "^1.50.0"
  }
}
