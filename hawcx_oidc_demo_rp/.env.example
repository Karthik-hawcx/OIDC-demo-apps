# Hawcx OIDC demo RP — sample config. Copy to .env and fill in.
# .env is gitignored by default (see .gitignore).

# OIDC issuer URL — the base of the Hawcx environment. Must match the
# `iss` claim in the id_token byte-for-byte (so no trailing slash).
HAWCX_OIDC_ISSUER=https://dev-demo-api.hawcx.com

# Hawcx project UUID. This is the `client_id` the RP sends to /authorize
# AND the `aud` claim the OP stamps into id_tokens for this project.
# Find it in the admin console (Settings → general → "Config ID" or
# the project URL), or in tenant_config's projects list.
HAWCX_CLIENT_ID=2551b799-00c8-470a-b8c2-1b5f1f5fa8b0

# Kong x-config-id header value (per-project SDK key). The RP sends this
# on the /oauth2/token request because Hawcx's token endpoint sits behind
# Kong key-auth — non-standard for OIDC, but how Hawcx is wired today.
# Same value the Hawcx web SDK uses as NEXT_PUBLIC_HAWCX_CONFIG_ID.
HAWCX_CONFIG_ID=aRHegUPgVnqxUagHes14bi0FnlrN3U2v

# Optional — defaults to HAWCX_CONFIG_ID. The SDK key the hosted login UI's
# JS uses when calling /v1/auth (it's forwarded to /login via the /authorize
# query string). Override only if your hosted-login project is different
# from the RP project (rare).
# HAWCX_SDK_CONFIG_ID=

# Where Hawcx will redirect after auth. Must be allowlisted in the
# project's oauth_config.redirect_uris on the OP side (admin console
# OAuth tab → add this URL → Save).
REDIRECT_URI=http://localhost:5000/callback

# Flask session secret. Auto-generated each restart if absent (which logs
# everyone out, fine for a demo). Set explicitly to keep sessions stable.
# FLASK_SECRET=

# Port the demo listens on locally. Update REDIRECT_URI to match if changed.
PORT=5000

# --- Optional: private_key_jwt (RFC 7523) confidential client ------------
# When these three are set AND the key file exists, the landing page shows
# a second "Sign in (private_key_jwt)" button alongside the public one — the
# flow is picked per-request via that UI switch (carried through the Flask
# session). HAWCX_AUTH_METHOD above only sets the DEFAULT for the plain nav
# "Sign in" link.
#
# Because the OP pins the auth method per client_id, the confidential flow
# uses a DIFFERENT client (HAWCX_CONFIDENTIAL_CLIENT_ID) than the public one
# (HAWCX_CLIENT_ID). If HAWCX_CONFIDENTIAL_CLIENT_ID is omitted it falls back
# to HAWCX_CLIENT_ID (single-client layout registered as private_key_jwt).
#
# Setup:
#   1. Generate a keypair:    python scripts/gen-rp-keypair.py acme-web
#   2. Register a client in the admin console with method=private_key_jwt
#      and paste the printed public JWK (Project → Settings → OAuth → Add JWK).
#   3. Fill in the three vars below.
#
# HAWCX_CONFIDENTIAL_CLIENT_ID=acme-web-confidential
# HAWCX_PRIVATE_KEY_PATH=./keys/private.pem
# HAWCX_PRIVATE_KEY_KID=acme-web-2026-05
